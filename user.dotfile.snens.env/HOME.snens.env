# Path to this File // For reinstallation purposes
setenv CONFIG_FILE_PATH "/home/snens_data/Dotfiles/snens.env/HOME.snens.env"

# Path to the User Home
setenv USER_HOME "$HOME"

# Path to the Config Home
setenv CONFIG_HOME "/home/snens_data/config_all"

# Path to the folders
setenv FOLDER_HOME "/home/snens_data/folders"

# Share
setenv SHARE_HOME "/home/snens_data/share/share"

# Secrets Home
setenv SECRETS_HOME "/home/snens_data/secrets"
